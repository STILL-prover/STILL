module parseTest begin

assume M is stype

theorem mTest: "M -o exists X:stype.X"
apply ImpliesR
apply Exists2R "M"
apply IdA
done

theorem testUnit: "1"
apply UnitR
done

theorem testMultiLine:
    "forall nat:Prop.
        forall a:nat.
            forall b:nat.1"
    apply ForallR
    apply ForallR+
    apply UnitR
done

theorem testTacticExpression: "forall nat:Type 0. forall a:nat. forall b:nat. 1"
apply ForallR+;UnitR
done

theorem testTacticExpression2: "forall nat:Prop.forall a:nat. forall b:nat. 1"
apply (ForallR <|> UnitR)+
done

theorem myT: "1 -o 1"
apply Intros
apply UnitLA -- test comment
apply UnitR {- test comment 
 -}
done
